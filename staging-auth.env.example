# Copia este archivo a .env.staging.local (no se sube a git)
# y completa con tus credenciales de staging.

BACKEND_URL=https://creditonegocios-staging.up.railway.app

# Opcion 1: login con usuario/password
STAGING_EMAIL=
STAGING_PASSWORD=

# Opcion 2: cookie de sesion (si usas esto, email/password no es obligatorio)
# STAGING_AUTH_COOKIE=connect.sid=...

# Opcional
FLUJO_1A1_REPORT_PATH=flujo-1a1-report.json
